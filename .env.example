# Database
# For Docker internal networking: postgresql://postgres:postgres@postgres:5432/shule?schema=public
# For local dev:            postgresql://postgres:postgres@localhost:5432/shule?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/shule?schema=public"

# NextAuth (REQUIRED - generate a strong secret for production)
AUTH_SECRET="your-secret-key-change-in-production"
AUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# Deployment domain (used by Traefik for routing)
DOMAIN="localhost"

# M-Pesa Daraja API (Safaricom)
MPESA_CONSUMER_KEY="your-consumer-key"
MPESA_CONSUMER_SECRET="your-consumer-secret"
MPESA_PASSKEY="your-passkey"
MPESA_SHORTCODE="174379"
MPESA_ENVIRONMENT="sandbox"
